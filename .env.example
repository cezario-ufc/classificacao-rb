# Copie este arquivo para .env e preencha as credenciais.
# .env nunca deve ser commitado (já está no .gitignore e .dockerignore).

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1

# Datasets a sincronizar (separados por espaco).
# Opcoes: oia-ddr idrid mesidor messidor-2 eoptha
# DATASETS=oia-ddr

# Bucket S3 de origem
# S3_BUCKET=retino-datasets-cezario